// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: {userId}
// Fields:
//   - uid: string (required) - The user's unique ID
//   - username: string (required) - The user's username
//   - likedSongs: array (optional) - List of liked songs
//   - playlists: array (optional) - List of user's private playlists
//   - favoriteArtists: array (optional) - List of favorite artists
//   - updatedAt: timestamp (optional) - Last update time
//
// Collection: public_playlists
// Document ID: {playlistId}
// Fields:
//   - id: string (required) - Unique ID for the playlist
//   - userId: string (required) - ID of the user who created it
//   - username: string (required) - Username of the creator
//   - title: string (required) - Playlist title
//   - description: string (optional) - Playlist description
//   - songs: array (required) - List of songs in the playlist
//   - createdAt: timestamp (required) - Creation time
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "nstrucks@gmail.com" && request.auth.token.email_verified == true));
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isValidUser(data) {
      return data.keys().hasAny(['likedSongs', 'playlists', 'favoriteArtists', 'updatedAt', 'uid', 'username', 'role']) &&
             (!('uid' in data) || data.uid is string) &&
             (!('username' in data) || (data.username is string && data.username.size() < 100)) &&
             (!('likedSongs' in data) || data.likedSongs is list) &&
             (!('playlists' in data) || data.playlists is list) &&
             (!('favoriteArtists' in data) || data.favoriteArtists is list) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp) &&
             (!('role' in data) || data.role in ['user', 'admin']);
    }

    function isValidPublicPlaylist(data) {
      return data.keys().hasAll(['id', 'userId', 'username', 'title', 'songs', 'createdAt']) &&
             data.id is string && data.id.size() > 0 &&
             data.userId is string && data.userId == request.auth.uid &&
             data.username is string && data.username.size() > 0 &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.songs is list && data.songs.size() <= 500 &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && 
                      (!('role' in request.resource.data) || request.resource.data.role == 'user' || isAdmin());
      allow update: if (isOwner(userId) && isValidUser(request.resource.data) && 
                        (!('role' in request.resource.data) || request.resource.data.role == resource.data.role || isAdmin())) || 
                      isAdmin();
      allow delete: if isAdmin();
    }

    match /public_playlists/{playlistId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidPublicPlaylist(request.resource.data);
      allow update, delete: if isDocOwner() && isValidPublicPlaylist(request.resource.data);
    }
  }
}
